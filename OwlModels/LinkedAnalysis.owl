<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:j.0="http://arcos.rack/PROV-S#"
    xmlns:An="http://arcos.rack/ANALYSIS#"
    xmlns:builtinfunctions="http://sadl.org/builtinfunctions#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:LnkAna="http://linkedUpdate/LinkedAnalysis#"
    xmlns:sadlimplicitmodel="http://sadl.org/sadlimplicitmodel#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:file="http://arcos.rack/FILE#"
    xmlns:sadlbasemodel="http://sadl.org/sadlbasemodel#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:Rq="http://arcos.rack/REQUIREMENTS#">
  <owl:Ontology rdf:about="http://linkedUpdate/LinkedAnalysis">
    <owl:imports rdf:resource="http://arcos.rack/ANALYSIS"/>
    <owl:imports rdf:resource="http://arcos.rack/FILE"/>
    <owl:imports rdf:resource="http://arcos.rack/REQUIREMENTS"/>
    <owl:imports rdf:resource="http://sadl.org/builtinfunctions"/>
    <owl:imports rdf:resource="http://sadl.org/sadlimplicitmodel"/>
    <owl:imports rdf:resource="http://sadl.org/sadlbasemodel"/>
    <rdfs:comment xml:lang="en">This ontology was created from a SADL file 'LinkedAnalysis.sadl' and should not be directly edited.</rdfs:comment>
  </owl:Ontology>
  <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#Analysis_Session">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:allValuesFrom>
          <owl:Class rdf:about="http://arcos.rack/ANALYSIS#ANALYSIS"/>
        </owl:allValuesFrom>
        <owl:onProperty rdf:resource="http://arcos.rack/PROV-S#wasGeneratedBy"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">Represents a session in the analysis process.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://arcos.rack/PROV-S#ENTITY"/>
  </owl:Class>
  <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#Analysis_File">
    <rdfs:comment xml:lang="en">Represents a file used or generated in the analysis process.</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#Linked_File"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#GE_Requirement">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:allValuesFrom rdf:resource="http://linkedUpdate/LinkedAnalysis#GE_Requirement"/>
        <owl:onProperty rdf:resource="http://arcos.rack/PROV-S#wasDerivedFrom"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="http://arcos.rack/REQUIREMENTS#REQUIREMENT"/>
  </owl:Class>
  <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#Linked_File">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onClass>
          <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#Repository"/>
        </owl:onClass>
        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#long"
        >1</owl:qualifiedCardinality>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="http://linkedUpdate/LinkedAnalysis#repositoryType"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="http://arcos.rack/FILE#FILE"/>
  </owl:Class>
  <owl:Class rdf:about="http://arcos.rack/ANALYSIS#ANALYSIS">
    <rdfs:comment xml:lang="en">ACTIVITY of running some analysis, and as a result creating some ANALYSIS_OUTPUT</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://arcos.rack/PROV-S#ACTIVITY"/>
  </owl:Class>
  <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#Repository">
    <owl:equivalentClass>
      <owl:Class>
        <owl:oneOf rdf:parseType="Collection">
          <LnkAna:Repository rdf:about="http://linkedUpdate/LinkedAnalysis#Cameo">
            <j.0:identifier>Cameo</j.0:identifier>
          </LnkAna:Repository>
          <LnkAna:Repository rdf:about="http://linkedUpdate/LinkedAnalysis#Volta">
            <j.0:identifier>Volta</j.0:identifier>
          </LnkAna:Repository>
          <LnkAna:Repository rdf:about="http://linkedUpdate/LinkedAnalysis#Teamcenter">
            <j.0:identifier>Teamcenter</j.0:identifier>
          </LnkAna:Repository>
        </owl:oneOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:resource="http://arcos.rack/PROV-S#THING"/>
  </owl:Class>
  <owl:Class rdf:about="http://linkedUpdate/LinkedAnalysis#Analysis_Folder">
    <rdfs:comment xml:lang="en">Represents a folder containing analysis files or other folders.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://arcos.rack/PROV-S#COLLECTION"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://linkedUpdate/LinkedAnalysis#verifiedBy">
    <rdfs:comment xml:lang="en">Verification artifact that verifies this requirement</rdfs:comment>
    <rdfs:range rdf:resource="http://arcos.rack/ANALYSIS#ANALYSIS_OUTPUT"/>
    <rdfs:domain rdf:resource="http://linkedUpdate/LinkedAnalysis#GE_Requirement"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://linkedUpdate/LinkedAnalysis#satisfies">
    <rdfs:subPropertyOf rdf:resource="http://arcos.rack/PROV-S#wasImpactedBy"/>
    <rdfs:comment xml:lang="en">ENTITY(s) (e.g. REQUIREMENT) that this folder participates in satisfying</rdfs:comment>
    <rdfs:range rdf:resource="http://arcos.rack/PROV-S#ENTITY"/>
    <rdfs:domain rdf:resource="http://linkedUpdate/LinkedAnalysis#Analysis_Folder"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://linkedUpdate/LinkedAnalysis#analyzedBy">
    <rdfs:comment xml:lang="en">Verification activity that verifies this requirement</rdfs:comment>
    <rdfs:range rdf:resource="http://arcos.rack/ANALYSIS#ANALYSIS"/>
    <rdfs:domain rdf:resource="http://linkedUpdate/LinkedAnalysis#GE_Requirement"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://linkedUpdate/LinkedAnalysis#repositoryType">
    <rdfs:comment xml:lang="en">The environment in which this file lives</rdfs:comment>
    <rdfs:range rdf:resource="http://linkedUpdate/LinkedAnalysis#Repository"/>
    <rdfs:domain rdf:resource="http://linkedUpdate/LinkedAnalysis#Linked_File"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://linkedUpdate/LinkedAnalysis#rationale">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="http://linkedUpdate/LinkedAnalysis#GE_Requirement"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://linkedUpdate/LinkedAnalysis#folderVersion">
    <rdfs:comment xml:lang="en">Version of the folder</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="http://linkedUpdate/LinkedAnalysis#Analysis_Folder"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://linkedUpdate/LinkedAnalysis#fileVersion">
    <rdfs:comment xml:lang="en">Version of the file.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="http://linkedUpdate/LinkedAnalysis#Analysis_File"/>
  </owl:DatatypeProperty>
</rdf:RDF>
