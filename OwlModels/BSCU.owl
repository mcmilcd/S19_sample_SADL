  <owl:ObjectProperty rdf:about="http://Ontology_BSCU/BSCU#parking_brake_lever">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="http://Ontology_BSCU/BSCU#BSCU_STATUS"/>
          <owl:Class rdf:about="http://Ontology_BSCU/BSCU#PILOT_CONTROLS"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://Ontology_BSCU/BSCU#COMMAND_STATUS"/>
    <rdfs:comment xml:lang="en">status of the parking brake lever set by pilot</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://Ontology_BSCU/BSCU#earth_reference_data">
    <rdfs:comment xml:lang="en">earth reference data</rdfs:comment>
    <rdfs:range rdf:resource="http://Ontology_BSCU/BSCU#EARTH_REFERENCE_DATA"/>
    <rdfs:domain rdf:resource="http://Ontology_BSCU/BSCU#BSCU"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://Ontology_BSCU/BSCU#mode">
